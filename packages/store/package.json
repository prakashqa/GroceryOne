    "react-redux": "^9.0.4"
  },
  "peerDependencies": {
    "@groceryone/shared": "1.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@groceryone/shared": "1.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
