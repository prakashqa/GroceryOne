{
  "name": "@groceryone/store",
  "version": "1.0.0",
  "description": "Shared Redux store, slices, and API definitions for GroOne",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
