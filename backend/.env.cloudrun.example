# ================================
# GroOne — Cloud Run Environment
# ================================
# Copy this file and fill in your actual values.
# Secrets (DB_PASSWORD, JWT_SECRET, REDIS_PASSWORD) are managed
# via GCP Secret Manager and injected by Cloud Run.

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# Database (Neon — free tier)
DB_HOST=ep-xxx.us-east-1.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neon_user
DB_NAME=groceryone
DB_SSL=true
# DB_PASSWORD → via Secret Manager

# Redis (Upstash — free tier)
REDIS_HOST=xxx.upstash.io
REDIS_PORT=6379
REDIS_TLS=true
# REDIS_PASSWORD → via Secret Manager

# JWT
# JWT_SECRET → via Secret Manager
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
