# ================================
# Docker Ignore for GroOne Backend
# ================================

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Build output (we build fresh in Docker)
dist

# Development files
.git
.gitignore
.env
.env.local
.env.*.local

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~

# Test files
coverage
.nyc_output
*.spec.ts
*.test.ts
test
__tests__

# Documentation
README.md
CHANGELOG.md
docs

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.log
*.tmp
tmp
temp

# Docker files (no need to copy these into image)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
