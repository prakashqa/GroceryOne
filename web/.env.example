# GroOne web — public (build-time) environment variables.
# Copy to .env.local and fill in. All NEXT_PUBLIC_* values are inlined into the
# client bundle at build time, so they must NOT contain secrets.

# Backend API base URL (e.g. https://api.groone.in/api/v1 in cloud,
# http://127.0.0.1:47600/api/v1 for the bundled desktop backend).
NEXT_PUBLIC_API_URL=

# Gate internal test tools (e.g. "Generate test barcodes"). Unset/empty in
# production; set to 1 to enable.
NEXT_PUBLIC_ENABLE_TEST_TOOLS=

# Desktop-license UPI payment (admin "Desktop license keys" screen).
# GroOne's collection VPA the ₹2,000/year license fee is paid TO — the SOFTWARE
# VENDOR's own UPI id, NOT a tenant/store merchant VPA. A built-in default ships
# in the code, so this is OPTIONAL — set it only to override that default. A
# static QR pre-fills payee + amount only; staff must still confirm the payment
# landed before minting the key.
NEXT_PUBLIC_GROONE_LICENSE_UPI_ID=
# Payee display name shown in the customer's UPI app (defaults to "GroOne").
NEXT_PUBLIC_GROONE_LICENSE_PAYEE=GroOne
