# ================================
# GroOne Docker Environment Variables
# ================================
# Copy this file to .env before running docker-compose
# cp .env.docker.example .env
# ================================

# -------- Application --------
NODE_ENV=development
BACKEND_PORT=3000
API_PREFIX=api/v1

# -------- Database (PostgreSQL) --------
DB_PORT=5432
DB_NAME=gro_one
DB_USERNAME=postgres
DB_PASSWORD=postgres

# -------- Cache (Redis) --------
REDIS_PORT=6379
REDIS_PASSWORD=

# -------- Authentication --------
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# -------- Security --------
CORS_ORIGIN=*

# -------- Rate Limiting --------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# -------- Seeding --------
AUTO_SEED=true
