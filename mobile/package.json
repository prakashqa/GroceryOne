{
  "name": "groceryone-mobile",
  "version": "1.0.0",
  "description": "GroOne Mobile Application",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "e2e:build": "detox build --configuration android.debug",
    "e2e:test": "detox test --configuration android.debug",
    "e2e:build:release": "detox build --configuration android.release",
    "e2e:test:release": "detox test --configuration android.release",
    "clean": "rimraf node_modules",
    "eas-build-pre-install": "cd ../packages/shared && npm install --legacy-peer-deps --ignore-scripts && npm run build"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@groceryone/shared": "*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-firebase/app": "^18.8.0",
    "@react-native-firebase/messaging": "^18.8.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@reduxjs/toolkit": "^2.0.1",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "~12.0.0",
    "expo": "^52",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.1",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-print": "~14.0.3",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "i18next": "^23.7.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^14.0.0",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.15.1",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-thermal-receipt-printer-image-qr": "^0.1.12",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "~0.19.13",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/runtime": "^7.23.8",
    "@react-native/babel-preset": "0.76.0",
    "@react-native/eslint-config": "0.76.0",
    "@react-native/typescript-config": "0.76.0",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.12",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "detox": "^20.17.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.3.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
